<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="cart.summary">
            <block
                class="Omnik\Core\Block\Cart\Sidebar"
                after="checkout.cart.summary.title"
                name="cart.free.shipping.progress.bar"
                template="Omnik_Core::cart/minicart.phtml"
            >
                <arguments>
                    <argument name="jsLayout" xsi:type="array">
                        <item name="components" xsi:type="array">
                            <item name="minicart-addons" xsi:type="array">
                                <item name="component" xsi:type="string">Omnik_Core/js/view/minicartaddons</item>
                                <item name="config" xsi:type="array">
                                    <item name="template" xsi:type="string">Omnik_Core/minicartaddons/content</item>
                                </item>
                            </item>
                        </item>
                    </argument>
                </arguments>
            </block>

        </referenceContainer>
    </body>
</page>
