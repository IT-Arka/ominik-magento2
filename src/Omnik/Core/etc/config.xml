<?xml version="1.0"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <omnik_integration>
            <general>
                <enable>1</enable>
                <mode>staging</mode>
                <url>https://api.sandbox.omnik.io/HUBSAN</url>
                <url_catalog>https://api.sandbox.omnik.io/v1/catalog</url_catalog>
                <url_freight>https://api.sandbox.omnik.io/v1/freight</url_freight>
                <timeout>300</timeout>
                <log_requests>1</log_requests>
                <boleto_extra_days>3</boleto_extra_days>
            </general>
            <address_mapping>
                <street_index_address>0</street_index_address>
                <street_index_number>1</street_index_number>
                <street_index_complement>2</street_index_complement>
                <street_index_neighborhood>3</street_index_neighborhood>
            </address_mapping>
            <product_attributes>
                <attr_tenant>tenant</attr_tenant>
                <attr_sku_id>sku_id_omnik</attr_sku_id>
                <attr_variant_seller>variant_seller</attr_variant_seller>
                <attr_variant_color>variant_color</attr_variant_color>
                <attr_variant_embalagem>variant_embalagem</attr_variant_embalagem>
                <attr_variant_tamanho>variant_tamanho</attr_variant_tamanho>
                <attr_erp_code>erp_code</attr_erp_code>
                <attr_brand>brand</attr_brand>
            </product_attributes>
        </omnik_integration>
        <omnik_grid_product_integration>
            <grid>
                <enable>0</enable>
            </grid>
        </omnik_grid_product_integration>
        <checkout>
            <cart>
                <freeshipping_progress_enable>0</freeshipping_progress_enable>
                <freeshipping_progress_min_total>0</freeshipping_progress_min_total>
            </cart>
        </checkout>
        <carriers>
            <omnik>
                <active>1</active>
                <sallowspecific>0</sallowspecific>
                <model>Omnik\Core\Model\Carrier\Method</model>
                <name>Omnik Shipping</name>
                <price></price>
                <title>Omnik Shipping</title>
            </omnik>
        </carriers>

        <payment>
            <splitorder>
                <active>1</active>
                <title>Split Order</title>
                <model>Omnik\Core\Model\SplitOrderPayment</model>
            </splitorder>
        </payment>
        <status_mapping>
            <mapping_table></mapping_table>
        </status_mapping>
        <advanced>
            <debug_mode>0</debug_mode>
            <sync_frequency>60</sync_frequency>
        </advanced>
        <omnik_core>
            <general>
                <attempts>3</attempts>
                <timeout_minutes>5</timeout_minutes>
            </general>
        </omnik_core>
    </default>
</config>
